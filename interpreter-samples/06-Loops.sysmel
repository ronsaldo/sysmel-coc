let: #x mutableWith: 0.

if: x = 0 then: {
    writeLine("x isZero")
} else: {
    writeLine("x not isZero")
}.

while: (x < 10) do: {
    writeLine("While: "). printLine(x)
} continueWith: (x := x + 1).

x := 0.
do: {
    writeLine("do continue while: "). printLine(x)
} continueWith: (x := x + 1) while: (x < 10).

x := 0.
do: {
    writeLine("Do while: "). printLine(x).
    x := x + 1.
} while: (x < 10).
